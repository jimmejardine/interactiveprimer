{
  // Type-checking only (`npm run typecheck` = `tsc -p tsconfig.json`); emission is esbuild's job
  // (scripts/build.mjs) and Node 24 runs the .ts sources directly via type stripping (tests, the
  // graph/i18n scripts). That split imposes two constraints, both enforced here:
  //   - allowImportingTsExtensions: internal imports use explicit ".ts" so the SAME specifier
  //     resolves under tsc, esbuild, and plain `node`.
  //   - erasableSyntaxOnly: no enums/namespaces/parameter properties — Node's type stripping
  //     erases types only, it cannot compile TS-specific runtime constructs.
  "compilerOptions": {
    "allowJs": true, // scripts/ stays plain JS tooling
    "checkJs": false, // JS is only checked where it opts in via @ts-check
    "strict": true,
    "noEmit": true,
    "module": "preserve",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "erasableSyntaxOnly": true,
    "target": "es2022",
    "lib": ["es2022", "dom", "dom.iterable"],
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": ["src/**/*", "test/**/*", "scripts/**/*"],
  "exclude": ["node_modules"]
}
