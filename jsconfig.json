{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "noEmit": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2022",
    "lib": ["es2022", "dom", "dom.iterable"],
    "types": ["node"],
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": { "primer": ["./js/primer.js"] }
  },
  "include": ["js/**/*.js", "js/**/*.d.ts", "test/**/*.js", "scripts/**/*.js"],
  "exclude": ["node_modules"]
}
