{
  "name": "interactiveprimer",
  "version": "0.0.1",
  "description": "Interactive Primer - smart web pages teaching a single tree of knowledge.",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "node --test",
    "typecheck": "tsc -p jsconfig.json",
    "graph": "node scripts/build-graph.js",
    "check:graph": "node scripts/build-graph.js --check",
    "stale": "node scripts/build-graph.js --stale",
    "i18n:check": "node scripts/i18n-check.js",
    "i18n:bless": "node scripts/i18n-check.js --update",
    "trim:png": "node scripts/trim-png.js",
    "vendor": "node scripts/vendor.mjs",
    "check": "npm run typecheck && npm test && npm run check:graph && npm run i18n:check",
    "serve": "node scripts/serve.js"
  },
  "devDependencies": {
    "@cortex-js/compute-engine": "^0.71.0",
    "@fontsource/fredoka": "^5.2.10",
    "@fontsource/stix-two-text": "^5.2.8",
    "@jitl/quickjs-singlefile-browser-release-sync": "^0.32.0",
    "@types/katex": "^0.16.8",
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "gif.js": "^0.2.0",
    "json5": "^2.2.3",
    "jsxgraph": "^1.12.2",
    "katex": "^0.17.0",
    "manim-web": "^0.3.23",
    "mathjax": "^3.2.2",
    "mathlive": "^0.110.0",
    "quickjs-emscripten-core": "^0.32.0",
    "sucrase": "^3.35.1",
    "typescript": "^5.9.3"
  },
  "license": "AGPL-3.0-or-later"
}
